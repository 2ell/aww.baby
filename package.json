{
  "name": "aww.baby",
  "author": "laurel",
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@grimlink/eleventy-plugin-lucide-icons": "^2.0.4",
    "eleventy-plugin-embed-spotify": "^1.3.0"
  },
  "scripts": {
    "start": "eleventy",
