<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Link CSS file(s) -->
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/style.css">
    <a rel="me" class="hide" href="https://social.lol/@laurel">Mastodon</a>
    <!-- Grab title from the page data and dump it here -->
    <title>{{ title }}{% if page.url != '/' %} | aww.baby{% endif %}</title>
</head>

<header>
    <div>
        <h1 class="title"><a href="/"><span>aww baby</span></a></h1>
        <p id="description"><i>this is currently a wip</i></p>
    </div>
    <div>
        {% include "components/nav.njk" %}
    </div>
</header>

<body>
    <div class="content">
        <!-- Grab the content from the page data, dump it here, and mark it as safe -->
        <!-- Safe docs: https://mozilla.github.io/nunjucks/templating.html#safe -->
        {{ content | safe }}
    </div>

    <footer>
        <div id="footer-cen">
            <p>made with {% lucide "heart", { "fill": "#F38BA8", "stroke-width": "0", "size": "14px" } %} by laurel</p>
            <p>built using <a href="https://11ty.dev">11ty</a> | hosted by <a href="https://www.netlify.com">netlify</a>
            </p>
        </div>
    </footer>

</body>

</html>