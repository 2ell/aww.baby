
<div class="post-list">
{% for post in collections.blog | reverse %}

<hr>
<div class="{{ post.data.type }}">
    <img src="{{ post.data.photo }}" class="card__image"/>
    <div class="card__content">
      <div class="card__date">
        <time span>{{ post.date | postDate }}</time>
    </div>
      <a href="{{ post.url }}"><span class="card__title">{{ post.data.title }}</span></a>
    </div>
    <div class="card__photodate">
    <time span>{{ post.date | postDate }}</time>
    </div>
    <div class="card__caption"><a href="{{ post.url }}">{{ post.data.caption }}</a></div>
  </div>
    {% endfor %}
</div>